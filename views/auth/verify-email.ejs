<%- include('../partials/header', { title: 'Email Varification' }) %>

<main class="container">
  <h1>Verify Your Email</h1>

  <div class="alert-container">
    <% if(user) { %>
    <div class="alert alert-success">
      <i class="fa-solid fa-circle-check"></i>
      <span>You are logged in</span>
    </div>
    <% } else { %>
    <div class="alert alert-warning">
      <i class="fa-solid fa-circle-exclamation"></i>
      <span>You are not logged in</span>
    </div>
    <% } %>
  </div>

  <div class="verify-card">
    <div class="verify-card-body">
      <p>
        <strong>Email:</strong>
        <%= email %>
      </p>
      <p>
        Your email has not been verified yet. Please verify your email by
        entering the 8-digit code or request a new verification link.
      </p>

      <form
        action="/resend-verification-link"
        method="post"
        class="form-inline"
      >
        <button type="submit" class="btn-verify">
          Resend Verification Link
        </button>
      </form>
    </div>
  </div>

  <div class="verify-card mt-20">
    <div class="verify-card-body">
      <form action="/verify-email-token" method="get" class="form">
        <div class="verify-form-group">
          <label for="token" class="control-label"
            >Enter 8-Digit Verification Code:</label
          >
          <input
            type="text"
            name="token"
            id="token"
            class="form-control"
            maxlength="8"
            required
            pattern="\d{8}"
            title="Please enter an 8-digit number"
          />
        </div>

        <input type="hidden" value="<%= email %>" name="email" />

        <button type="submit">Verify Code</button>
      </form>
    </div>
  </div>
</main>
<% if (typeof previewUrl !== "undefined" && previewUrl) { %>
<script>
  window.open('<%= previewUrl %>', '__parent');
</script>
<% } %>
<%- include('../partials/footer') %>
