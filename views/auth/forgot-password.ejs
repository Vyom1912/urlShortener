<%- include('../partials/header', { title: 'Reset Password' }) %>
<section class="change-password forgot-password">
  <div class="container">
    <div class="change-password-content">
      <div class="alert-container">
        <% if(user) { %>
        <div class="alert alert-success">
          <i class="fa-solid fa-circle-check"></i>
          <span>You are logged in</span>
        </div>
        <% } else { %>
        <div class="alert alert-warning">
          <i class="fa-solid fa-circle-exclamation"></i>
          <span>You are not logged in</span>
        </div>
        <% } %>
      </div>

      <% if(formSubmitted) { %>
      <p>
        If the email that you have given us is correct, we have sent email to
        reset password to your email.
      </p>
      <% } else { %>
      <div class="change-password-form">
        <h2 class="form-title">Enter Your Register Email</h2>
        <form action="/reset-password" method="post">
          <div class="form-group">
            <label for="email"></label>
            <div class="input-group">
              <i class="fa-solid fa-envelope"></i>
              <input
                type="email"
                name="email"
                id="email"
                placeholder="Enter your Register Email"
                autocomplete="false"
              />
            </div>
          </div>

          <% if ((errors && errors.length > 0)) { %>
          <div class="error-container">
            <% errors.forEach((error) => { %>
            <p class="flash-error"><%= error %></p>
            <% }); %>
          </div>
          <% } %>

          <div class="form-group form-button">
            <button type="submit" class="form-submit">Submit</button>
          </div>
        </form>
      </div>
    </div>
    <% } %>
  </div>
</section>
<%- include('../partials/footer') %>
